# TypeScript source at root — consumers use the compiled lib/
/src/
/index.ts
/jest.config.ts
/tsconfig.json

# Source maps — not needed by consumers and flagged as obfuscated by security scanners
**/*.js.map
**/*.d.ts.map

# Compiled test files — not needed by consumers
lib/src/**/*.test.js
lib/src/**/*.test.d.ts

# Compiled Jest config — not needed by consumers
lib/jest.config.js
lib/jest.config.d.ts

